---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="clinics" id="clinics">
  <div class="container">
    <div class="clinics-header text-center">
      <div class="section-label mx-auto" style="justify-content: center;">{t('clinics.label')}</div>
      <h2 class="section-heading">{t('clinics.title')}</h2>
      <p class="section-subheading mx-auto text-center">
        {t('clinics.subtitle')}
      </p>
    </div>

    <div class="clinics-grid">
      <!-- Meret General Clinic -->
      <div class="card clinic-card">
        <div class="clinic-card-header">
          <div class="icon-badge" style="background: #f0f9ff; color: #0369a1;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"></path>
              <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path>
              <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"></path>
              <path d="M10 6h4"></path>
              <path d="M10 10h4"></path>
              <path d="M10 14h4"></path>
              <path d="M10 18h4"></path>
            </svg>
          </div>
          <div>
            <h3 class="clinic-name">{t('clinics.general.title')}</h3>
            <span class="clinic-sub">{t('clinics.general.sub')}</span>
          </div>
        </div>

        <div class="clinic-tags">
          <span class="tag tag-teal">{t('clinics.general.tag1')}</span>
          <span class="tag tag-teal">{t('clinics.general.tag2')}</span>
          <span class="tag tag-teal">{t('clinics.general.tag3')}</span>
          <span class="tag tag-teal">{t('clinics.general.tag4')}</span>
          <span class="tag tag-teal">{t('clinics.general.tag5')}</span>
          <span class="tag tag-teal">{t('clinics.general.tag6')}</span>
          <span class="tag tag-teal">{t('clinics.general.tag7')}</span>
          <span class="tag tag-teal">{t('clinics.general.tag8')}</span>
        </div>

        <div class="clinic-note">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
          </svg>
          <span>{t('clinics.general.note')}</span>
        </div>

        <a href="#" class="btn btn-gold btn-block">{t('clinics.general.btn')}</a>
      </div>

      <!-- Meret Family Doctor -->
      <div class="card clinic-card">
        <div class="clinic-card-header">
          <div class="icon-badge" style="background: rgba(212, 175, 55, 0.1); color: var(--gold);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <div>
            <h3 class="clinic-name">{t('clinics.family.title')}</h3>
            <span class="clinic-sub" style="color: var(--gold);">{t('clinics.family.sub')}</span>
          </div>
        </div>

        <ul class="clinic-features">
          <li>{t('clinics.family.li1')}</li>
          <li>{t('clinics.family.li2')}</li>
          <li>{t('clinics.family.li3')}</li>
          <li>{t('clinics.family.li4')}</li>
        </ul>

        <div class="clinic-quote">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <em>{t('clinics.family.quote')}</em>
        </div>

        <a href="#" class="btn btn-gold btn-block">{t('clinics.family.btn')}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .clinics {
    padding: var(--section-padding) 0;
    background: var(--light-bg);
  }

  .clinics-header {
    margin-bottom: 56px;
  }

  .clinics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .clinic-card {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .clinic-card-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .clinic-card-header .icon-badge {
    margin-bottom: 0;
    flex-shrink: 0;
  }

  .clinic-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 2px;
  }

  .clinic-sub {
    font-size: 0.85rem;
    color: var(--teal);
    font-weight: 500;
  }

  .clinic-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  /* Border-less Light Blue Gradient Tags */
  .clinic-tags .tag {
    border: none !important;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    color: #0369a1;
    padding: 8px 18px;
    font-weight: 600;
    font-size: 0.85rem;
    box-shadow: 0 2px 8px rgba(3, 105, 161, 0.05);
    transition: all 0.3s ease;
  }

  .clinic-tags .tag:hover {
    transform: translateY(-2px);
    background: white;
    box-shadow: 0 4px 12px rgba(3, 105, 161, 0.1);
    color: #0c4a6e;
  }

  .clinic-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 16px;
    background: var(--lighter-bg);
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-body);
  }

  .clinic-note svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .clinic-features {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .clinic-features li {
    position: relative;
    padding-left: 22px;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-body);
  }

  .clinic-features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }

  .clinic-quote {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 16px;
    background: rgba(200, 164, 92, 0.06);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--gold);
  }

  .clinic-quote svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .clinic-quote em {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-body);
    font-style: italic;
  }

  .clinic-card .btn-block {
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .clinics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
