---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="intro">
  <div class="container">
    <p class="intro-text" set:html={t('intro.text')} />
  </div>
</section>

<style>
  .intro {
    padding: 80px 0;
    background: var(--white);
  }

  .intro-text {
    max-width: 820px;
    margin: 0 auto;
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--text-body);
    text-align: center;
  }

  .intro-text strong {
    color: var(--text-heading);
    font-weight: 600;
  }

  .intro-link {
    color: var(--gold);
    font-weight: 600;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition-fast);
  }

  .intro-link:hover {
    border-bottom-color: var(--gold);
  }

  @media (max-width: 768px) {
    .intro {
      padding: 48px 0;
    }

    .intro-text {
      font-size: 0.95rem;
      text-align: left;
    }
  }
</style>
