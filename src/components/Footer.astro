<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="#" class="footer-logo">
          <div class="footer-logo-icon">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
              <rect width="32" height="32" rx="8" fill="#c8a45c"/>
              <path d="M8 22V10l8 6 8-6v12" stroke="#0f2a3d" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>
          <span class="footer-logo-text">Meret <span class="footer-logo-accent">Health</span></span>
        </a>
        <p class="footer-tagline">
          Hệ sinh thái chăm sóc sức khỏe cá thể hóa dựa trên dữ liệu và AI tại Việt Nam.
        </p>
      </div>

      <!-- Dịch vụ column -->
      <div class="footer-col">
        <h4 class="footer-col-title">DỊCH VỤ</h4>
        <ul class="footer-links">
          <li><a href="#diagnostics">Xét nghiệm chuyên sâu</a></li>
          <li><a href="#diagnostics">Chẩn đoán hình ảnh AI</a></li>
          <li><a href="#clinics">Phòng khám Đa khoa</a></li>
          <li><a href="#clinics">Bác sĩ Gia đình</a></li>
        </ul>
      </div>

      <!-- Công ty column -->
      <div class="footer-col">
        <h4 class="footer-col-title">CÔNG TY</h4>
        <ul class="footer-links">
          <li><a href="#about">Về chúng tôi</a></li>
          <li><a href="#ecosystem">Hệ sinh thái</a></li>
          <li><a href="#cta">Liên hệ</a></li>
        </ul>
      </div>

      <!-- Liên hệ column -->
      <div class="footer-col">
        <h4 class="footer-col-title">LIÊN HỆ</h4>
        <ul class="footer-contact">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Hà Nội, Việt Nam</span>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <a href="mailto:info@merethealth.vn">info@merethealth.vn</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span class="footer-copyright">© 2025 Meret Health. All rights reserved.</span>
      <span class="footer-motto">Data · AI · Care</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy-darkest);
    padding: 64px 0 0;
    border-top: 1px solid var(--border-dark);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--border-dark);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 16px;
  }

  .footer-logo-text {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--white);
  }

  .footer-logo-accent {
    color: var(--gold);
    font-weight: 500;
  }

  .footer-tagline {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-light);
    max-width: 280px;
  }

  .footer-col-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 20px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    font-size: 0.9rem;
    color: var(--text-light);
    opacity: 0.7;
    transition: all var(--transition-fast);
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--gold);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-contact li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--text-light);
    opacity: 0.7;
  }

  .footer-contact svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .footer-contact a {
    color: var(--text-light);
    opacity: 1;
  }

  .footer-contact a:hover {
    color: var(--gold);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
  }

  .footer-copyright {
    font-size: 0.85rem;
    color: var(--text-light);
    opacity: 0.5;
  }

  .footer-motto {
    font-size: 0.85rem;
    color: var(--text-light);
    opacity: 0.4;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .footer-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: span 1;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>
